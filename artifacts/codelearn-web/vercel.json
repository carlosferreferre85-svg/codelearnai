{
  "framework": "vite",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/chat/generate-image", "destination": "/api/chat/generate-image" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
